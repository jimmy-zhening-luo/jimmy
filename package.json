{
  "name": "jimmy",
  "description": "Jimmy Luo personal website",
  "version": "8.1.0",
  "author": "Zhening Jimmy Luo",
  "license": "MIT",
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmy-zhening-luo/jimmy.git"
  },
  "bugs": {
    "url": "https://github.com/jimmy-zhening-luo/jimmy/issues"
  },
  "homepage": "https://github.com/jimmy-zhening-luo/jimmy#readme",
  "scripts": {
    "clean": "rimraf ./dist/*",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "prebuild": "npm run clean",
    "build:server": "tsc",
    "build:client": "rollup -c",
    "build": "npm run build:server",
    "postbuild": "npm run build:client",
    "start": "node ./dist/server.js",
    "predev:start": "npm run build",
    "dev:start": "npm run start",
    "dev": "nodemon --watch src -e ts,svelte --exec npm run dev:start",
    "premock": "npm run mock:client",
    "mock:client": "rollup -c -w",
    "mock": "sirv dist"
  },
  "engines": {
    "npm": ">=8.11.0",
    "node": ">=16.16.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^10.0.0",
    "express": "^4.18.1",
    "express-session": "^1.17.3",
    "fs-extra": "^10.1.0",
    "node": "^16.16.0",
    "npm": "^8.11.0",
    "sirv-cli": "^2.0.2",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^22.0.2",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@rollup/plugin-typescript": "^8.4.0",
    "@tsconfig/svelte": "^3.0.0",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/express-session": "^1.17.5",
    "@types/fs-extra": "^9.0.13",
    "@types/node": "^16.11.56",
    "autoprefixer": "^10.4.8",
    "nodemon": "^2.0.19",
    "postcss": "^8.4.16",
    "pug": "^3.0.2",
    "rimraf": "^3.0.2",
    "rollup": "^2.79.0",
    "rollup-plugin-css-only": "^3.1.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-svelte": "^7.1.0",
    "rollup-plugin-terser": "^7.0.2",
    "sass": "^1.54.8",
    "svelte": "^3.50.0",
    "svelte-check": "^2.9.0",
    "svelte-preprocess": "^4.10.7",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.2"
  }
}
